# Local environment configuration for TradingAgents with vLLM
#
# Copy this file to .env.local and update values as needed.
# Then load it with: export $(grep -v '^#' .env.local | xargs)
# Or use python-dotenv: load_dotenv('.env.local')

# =============================================================================
# LLM Providers
# =============================================================================
# For local vLLM: no API key needed, but langchain-openai requires one.
# Set a dummy key to satisfy the API key requirement.
OPENAI_API_KEY=dummy

# Set the vLLM backend URL (uncomment for local vLLM)
# BACKEND_URL=http://192.168.50.144:8036/v1

# Uncomment if using other providers
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# ANTHROPIC_API_KEY=...
# XAI_API_KEY=...
# DEEPSEEK_API_KEY=...
# DASHSCOPE_API_KEY=...
# ZHIPU_API_KEY=...
# OPENROUTER_API_KEY=...

# =============================================================================
# Data Vendors
# =============================================================================
# For TradeStation: no API key needed when running in OpenClaw runtime
# For Alpha Vantage (if used):
# ALPHA_VANTAGE_API_KEY=...

# =============================================================================
# TradingAgents Settings
# =============================================================================
TRADINGAGENTS_RESULTS_DIR=~/.tradingagents/logs
TRADINGAGENTS_CACHE_DIR=~/.tradingagents/cache
TRADINGAGENTS_MEMORY_LOG_PATH=~/.tradingagents/memory/trading_memory.md
